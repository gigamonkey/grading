<tr id="student-assignment-row-{{ a.assignment_id }}"
    hx-get="/students/{{ userId }}/assignments/{{ a.assignment_id }}/row"
    hx-trigger="student-assignment-reloaded[event.detail.value=='{{ userId }}-{{ a.assignment_id }}'] from:body"
    hx-swap="outerHTML">
  <td>
    <a href="/assignments/{{ a.assignment_id }}/students">{{ a.title }}</a>
    {% if reloadKind and student.github %}
    <span class="reload-status" style="display:inline-block; margin-left: 0.3em; opacity: 0.3;">
      <a href="#" title="Reload and grade" style="color: inherit; font-size: 0.75em;"
         hx-post="/students/{{ userId }}/assignments/{{ a.assignment_id }}/reload"
         hx-target="closest .reload-status"
         hx-swap="innerHTML"
         hx-indicator="closest .reload-status"
         onclick="event.preventDefault()">
        <i class="bi bi-arrow-clockwise"></i>
      </a>
    </span>
    {% endif %}
  </td>
  <td>{{ a.date }}</td>
  <td>{{ a.ic_name }}</td>
  <td>{% if a.score != null %}{{ (a.score * 100) | round }}%{% else %}&mdash;{% endif %}</td>
  <td>{% if a.points != null %}{{ a.points }} / {{ a.max_points }}{% else %}&mdash;{% endif %}</td>
</tr>
