{% extends "app/layout.njk" %}
{% block title %}{{ student.sortable_name }} - Gradebook{% endblock %}
{% block content %}
{% set userJson = {period: student.period, userId: student.user_id, studentNumber: student.student_number, email: student.email, github: student.github, name: student.name, pronouns: student.pronouns, googleName: student.google_name, sortableName: student.sortable_name, lastName: student.last_name, firstName: student.first_name, birthdate: student.birthdate, courseId: student.course_id} %}
<h1>{{ student.name }} <small>({{ student.sortable_name }})</small> <span class="copyable" data-copy="{{ userJson | dump | e }}" onclick="navigator.clipboard.writeText(this.dataset.copy)" style="cursor: pointer;"><i class="bi bi-clipboard copy-icon" style="font-size: 0.5em; vertical-align: middle;"></i></span></h1>

<table class="info-table fit">
  <thead>
    <tr><th>Student #</th><th>Course</th><th>Period</th><th>Email</th><th>GitHub</th></tr>
  </thead>
  <tbody>
    <tr>
      <td class="copyable" style="text-align: center;" onclick="navigator.clipboard.writeText('{{ student.student_number }}')">{{ student.student_number }} <i class="bi bi-clipboard copy-icon"></i></td>
      <td style="text-align: center;">{{ student.course_id }}</td>
      <td style="text-align: center;">{{ student.period }}</td>
      <td class="copyable" onclick="navigator.clipboard.writeText('{{ student.email }}')">{{ student.email.split('@')[0] }}@ <i class="bi bi-clipboard copy-icon"></i></td>
      <td><a href="https://gigamonkeys.com/berkeley-high-cs/{{ student.github }}">{{ student.github }}</a></td>
    </tr>
  </tbody>
</table>

<h2>Assignment Scores</h2>
<table class="data-table fit">
  <thead>
    <tr>
      <th>Assignment</th>
      <th>Date</th>
      <th>IC Name</th>
      <th>Score</th>
      <th>Points</th>
    </tr>
  </thead>
  <tbody>
    {% for a in assignments %}
    {% set userId = student.user_id %}{% set reloadKind = reloadKinds[a.assignment_id] %}
    {% include "app/students/assignment-row.njk" %}
    {% else %}
    <tr><td colspan="5">No assignment scores.</td></tr>
    {% endfor %}
  </tbody>
</table>

<h2>Mastery Totals by Standard</h2>
<table class="fit">
  <thead>
    <tr><th>Standard</th><th>Points</th></tr>
  </thead>
  <tbody>
    {% for t in masteryTotals %}
    <tr><td>{{ t.standard }}</td><td>{{ t.points }}</td></tr>
    {% else %}
    <tr><td colspan="2">No mastery points.</td></tr>
    {% endfor %}
  </tbody>
</table>

<h2>All Mastery Points</h2>
<table class="fit" data-column-filters>
  <thead>
    <tr>
      <th data-column-filter="0">Standard</th>
      <th data-column-filter="1">Type</th>
      <th>Points</th>
      <th>Source</th>
      <th>Date</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    {% for p in masteryPoints %}
    <tr>
      <td>{{ p.standard }}</td>
      <td>{{ p.type }}</td>
      {% if p.rowid %}
      {% set rowid = p.rowid %}{% set points = p.points %}{% include "app/ad-hoc-mastery/points-cell.njk" %}
      {% else %}
      <td>{{ p.points }}</td>
      {% endif %}
      <td>{{ p.source }}</td>
      <td>{{ p.date }}</td>
      <td>{% if p.rowid %}<i class="bi bi-trash delete-icon" hx-delete="/ad-hoc-mastery/{{ p.rowid }}" hx-target="closest tr" hx-swap="outerHTML" hx-confirm="Delete this score?"></i>{% endif %}</td>
    </tr>
    {% else %}
    <tr><td colspan="6">No mastery points.</td></tr>
    {% endfor %}
  </tbody>
</table>

<h2>Speedruns</h2>
<table class="fit">
  <thead>
    <tr><th>Assignment</th><th>Finished</th><th>Status</th></tr>
  </thead>
  <tbody>
    {% for s in speedruns %}
    <tr>
      <td>{{ s.title or s.assignment_id }}</td>
      <td>{{ s.finished_at | epochDate }}</td>
      <td>
        <a href="/speedruns/{{ s.speedrun_id }}">
        {% if s.ok == null %}
          Ungraded
        {% elif s.ok == 1 %}
          <span class="text-success">Accepted</span>
        {% else %}
          <span class="text-danger">Rejected</span>
        {% endif %}
        </a>
      </td>
    </tr>
    {% else %}
    <tr><td colspan="3">No speedruns.</td></tr>
    {% endfor %}
  </tbody>
</table>
{% endblock %}
