{% for p in rows %}
<tr>
  <td><a href="/students/{{ p.user_id }}">{{ p.sortable_name }}</a></td>
  <td>{{ p.period }}</td>
  <td>{{ p.course_id }}</td>
  <td>{{ p.standard }}</td>
  {% set rowid = p.rowid %}{% set points = p.points %}{% include "app/ad-hoc-mastery/points-cell.njk" %}
  <td><a href="/ad-hoc-mastery/reason/{{ p.reason | urlencode }}?standard={{ p.standard | urlencode }}">{{ p.reason }}</a></td>
  <td>{{ p.date }}</td>
  <td><i class="bi bi-trash delete-icon" hx-delete="/ad-hoc-mastery/{{ p.rowid }}" hx-target="closest tr" hx-swap="outerHTML" hx-confirm="Delete this score?"></i></td>
</tr>
{% else %}
<tr><td colspan="8">No ad hoc mastery points found.</td></tr>
{% endfor %}
