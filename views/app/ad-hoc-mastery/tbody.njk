{% for p in points %}
<tr>
  <td><a href="/ad-hoc-mastery/student/{{ p.user_id }}">{{ p.sortable_name }}</a></td>
  <td>{{ p.period }}</td>
  <td>{{ p.course_id }}</td>
  <td>{{ p.standard }}</td>
  <td>{{ p.points }}</td>
  <td><a href="/ad-hoc-mastery/reason/{{ p.reason | urlencode }}?standard={{ p.standard | urlencode }}">{{ p.reason }}</a></td>
  <td>{{ p.date }}</td>
</tr>
{% else %}
<tr><td colspan="7">No ad hoc mastery points found.</td></tr>
{% endfor %}
