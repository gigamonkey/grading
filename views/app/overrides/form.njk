<form hx-post="/overrides" hx-target="#overrides-tbody" hx-swap="innerHTML">
  <fieldset>
    <legend>Student</legend>
    <input type="search" placeholder="Search by name or GitHub..."
      hx-get="/overrides/search-students"
      hx-trigger="input delay:300ms"
      hx-target="#student-results"
      name="q">
    <div id="student-results"></div>
  </fieldset>

  <fieldset>
    <legend>Assignment</legend>
    <input type="search" placeholder="Search by ID or title..."
      hx-get="/overrides/search-assignments"
      hx-trigger="input delay:300ms"
      hx-target="#assignment-results"
      name="q">
    <div id="assignment-results"></div>
  </fieldset>

  <label>Score <input type="number" name="score" step="0.01" required></label>
  <label>Reason <input type="text" name="reason" required></label>
  <button type="submit">Add Override</button>
</form>
