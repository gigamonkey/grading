{% extends "app/layout.njk" %}
{% block title %}{{ icName }} - Gradebook{% endblock %}
{% block content %}
<h1>{{ icName }} <span class="copyable" data-copy="{{ icName }}" onclick="navigator.clipboard.writeText(this.dataset.copy)" style="cursor: pointer;"><i class="bi bi-clipboard copy-icon" style="font-size: 0.5em; vertical-align: middle;"></i></span></h1>
{% if assignment %}<p><a href="/assignments/{{ assignment.assignment_id }}/students">{{ assignment.title }}</a> &middot; {{ assignment.date }} &middot; {{ assignment.points }} points</p>{% endif %}
<table class="ic-assignment-table" data-column-filters data-row-highlight>
  <thead>
    <tr><th data-column-filter="0">Period</th><th>Student</th><th>Points</th></tr>
  </thead>
  <tbody>
    {% for r in rows %}
    <tr>
      <td>{{ r.period }}</td>
      <td><a href="/students/{{ r.user_id }}">{{ r.sortable_name }}</a></td>
      <td>{{ r.points }}</td>
    </tr>
    {% else %}
    <tr><td colspan="3">No scores found.</td></tr>
    {% endfor %}
  </tbody>
</table>

<script src="/js/row-highlight.js"></script>
{% endblock %}
