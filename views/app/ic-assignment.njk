{% extends "app/layout.njk" %}
{% block title %}{{ icName }} - Gradebook{% endblock %}
{% block content %}
<h1>
  <span id="ic-name-text">{{ icName }}</span>
  <span class="copyable" data-copy="{{ icName }}" onclick="navigator.clipboard.writeText(this.dataset.copy)" style="cursor: pointer;"><i class="bi bi-clipboard copy-icon" style="font-size: 0.5em; vertical-align: middle;"></i></span>
  <span style="cursor: pointer;" onclick="startEditIcName(this)"><i class="bi bi-pencil copy-icon" style="font-size: 0.5em; vertical-align: middle;"></i></span>
</h1>
<script>
function startEditIcName(trigger) {
  const span = document.getElementById('ic-name-text');
  if (span.querySelector('input')) return;
  const current = span.textContent;
  const input = document.createElement('input');
  input.type = 'text';
  input.value = current;
  input.style.fontSize = 'inherit';
  input.style.fontWeight = 'inherit';
  span.textContent = '';
  span.appendChild(input);
  input.focus();
  input.select();

  let cancelled = false;
  function submit() {
    if (cancelled) return;
    const value = input.value.trim();
    if (!value || value === current) {
      span.textContent = current;
      return;
    }
    htmx.ajax('PUT', `/ic-assignment/${encodeURIComponent(current)}/name`, {
      values: { icName: value },
    });
  }
  input.addEventListener('blur', submit);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
    if (e.key === 'Escape') { cancelled = true; span.textContent = current; }
  });
}
</script>
{% if not existsInIc and assignment %}<p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Add to IC under standard “{{ assignment.standard }}”</p>{% elif not existsInIc %}<p class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Not found in IC gradebook</p>{% endif %}
{% if assignment %}<p><a href="/assignments/{{ assignment.assignment_id }}/students">{{ assignment.title }}</a> &middot; {{ assignment.date }} &middot; {{ assignment.points }} points</p>{% endif %}
<table class="ic-assignment-table" data-column-filters data-row-highlight>
  <thead>
    <tr><th data-column-filter="0">Period</th><th>Student</th><th>Points <span class="copyable" style="cursor: pointer;" onclick="navigator.clipboard.writeText([...document.querySelectorAll('.ic-assignment-table tbody tr')].filter(tr => tr.offsetParent !== null).map(tr => tr.children[2].textContent).join('\n'))"><i class="bi bi-clipboard copy-icon" style="font-size: 0.75em; vertical-align: middle;"></i></span></th></tr>
  </thead>
  <tbody>
    {% for r in rows %}
    <tr>
      <td>{{ r.period }}</td>
      <td><a href="/students/{{ r.user_id }}">{{ r.sortable_name }}</a></td>
      <td>{{ r.points }}</td>
    </tr>
    {% else %}
    <tr><td colspan="3">No scores found.</td></tr>
    {% endfor %}
  </tbody>
</table>

<script src="/js/row-highlight.js"></script>
{% endblock %}
