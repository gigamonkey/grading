{% extends "app/layout.njk" %}
{% block title %}Checklist Grader - Gradebook{% endblock %}
{% block content %}
<h1>Checklist Grader</h1>
<input type="search" placeholder="Search assignments..."
  value="{{ search or '' }}"
  hx-get="/checklist"
  hx-trigger="input delay:300ms"
  hx-target="#checklist-tbody"
  hx-include="this"
  name="search">
<table>
  <thead>
    <tr>
      <th>ID</th><th>Title</th><th>Course</th><th>Date</th><th>Type</th><th>Standard</th>
    </tr>
  </thead>
  <tbody id="checklist-tbody">
    {% include "app/checklist/tbody.njk" %}
  </tbody>
</table>
{% endblock %}
