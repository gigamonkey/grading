<div hx-vals='{"sort": "{{ sort }}", "dir": "{{ dir }}", "prevSort": "{{ prevSort if prevSort else '' }}", "prevDir": "{{ prevDir }}"}'>
<table class="checklist">
  <thead>
    <tr>
      {% set base = '/points-grader/' + assignment.assignment_id %}
      {% macro sortLink(key, label) %}
        {% set qsTail = ('&prevSort=' + sort + '&prevDir=' + dir) if sort != key else (('&prevSort=' + prevSort + '&prevDir=' + prevDir) if prevSort else '') %}
        {{ label }}<span class="sort-carets"
          ><a class="sort-up{% if sort == key and dir == 'desc' %} active{% endif %}"
              href="{{ base }}?sort={{ key }}&dir=desc{{ qsTail }}"><i class="bi bi-caret-up-fill"></i></a
          ><a class="sort-down{% if sort == key and dir == 'asc' %} active{% endif %}"
              href="{{ base }}?sort={{ key }}&dir=asc{{ qsTail }}"><i class="bi bi-caret-down-fill"></i></a
        ></span>
      {% endmacro %}
      <th>{{ sortLink('name', 'Name') }} / {{ sortLink('github', 'Github') }}</th>
      <th>{{ sortLink('score', 'Score') }}</th>
      <th>{{ sortLink('points', 'Points') }}</th>
      {% for i in items %}
        <th class="checklist-item">
          {% set itemKey = 'item:' + i.seq %}
          {% set qsTail = ('&prevSort=' + sort + '&prevDir=' + dir) if sort != itemKey else (('&prevSort=' + prevSort + '&prevDir=' + prevDir) if prevSort else '') %}
          <span class="sort-carets">
            <a class="sort-up{% if sort == itemKey and dir == 'desc' %} active{% endif %}"
               href="{{ base }}?sort={{ itemKey }}&dir=desc{{ qsTail }}"><i class="bi bi-caret-up-fill"></i></a>
            <a class="sort-down{% if sort == itemKey and dir == 'asc' %} active{% endif %}"
               href="{{ base }}?sort={{ itemKey }}&dir=asc{{ qsTail }}"><i class="bi bi-caret-down-fill"></i></a>
          </span>
          {% set assignmentId = assignment.assignment_id %}
          {% set seq = i.seq %}
          {% set label = i.label %}
          {% set editing = false %}
          {% include "app/points-grader/label-cell.njk" %}
          {% set points = i.points %}
          {% set editing = false %}
          {% include "app/points-grader/item-points-cell.njk" %}
          {% if i.kind == 'image_refactoring' %}
          <button type="button" class="btn-subtle"
                  title="Render all students for this item (slow)"
                  hx-post="/points-grader/{{ assignment.assignment_id }}/items/{{ i.seq }}/render-all"
                  hx-target="#points-grader-table"
                  hx-swap="innerHTML"
                  hx-disabled-elt="this"
                  hx-confirm="Render all students for this item? This can take a while.">
            <i class="bi bi-image"></i> Render all
          </button>
          {% endif %}
        </th>
      {% endfor %}
      <th>
        <details class="add-item-menu">
          <summary><i class="bi bi-plus-lg"></i> Add</summary>
          <div class="add-item-menu-items">
            <button type="button"
                    hx-post="/points-grader/{{ assignment.assignment_id }}/items"
                    hx-vals='{"label": "-"}'
                    hx-target="#points-grader-table"
                    hx-swap="innerHTML"
                    onclick="this.closest('details').open=false"><i class="bi bi-percent"></i> Percent</button>
            <button type="button"
                    hx-post="/points-grader/{{ assignment.assignment_id }}/check-item"
                    hx-vals='{"label": "-"}'
                    hx-target="#points-grader-table"
                    hx-swap="innerHTML"
                    onclick="this.closest('details').open=false"><i class="bi bi-check-lg"></i> Check</button>
            <button type="button"
                    hx-post="/points-grader/{{ assignment.assignment_id }}/extra-credit-item"
                    hx-vals='{"label": "EC"}'
                    hx-target="#points-grader-table"
                    hx-swap="innerHTML"
                    onclick="this.closest('details').open=false"><i class="bi bi-plus-circle"></i> Extra credit</button>
            <button type="button"
                    onclick="document.getElementById('n-of-m-dialog').showModal();this.closest('details').open=false"><i class="bi bi-list-ol"></i> N of M&hellip;</button>
            <button type="button"
                    onclick="document.getElementById('commits-dialog').showModal();this.closest('details').open=false"><i class="bi bi-clock-history"></i> Commits&hellip;</button>
            <button type="button"
                    onclick="document.getElementById('image-refactor-dialog').showModal();this.closest('details').open=false"><i class="bi bi-image"></i> Image&hellip;</button>
          </div>
        </details>
      </th>
  </thead>
  <tbody>
    {% for s in students %}
    {% set earned = studentPoints[s.user_id] %}
    {% set complete = studentComplete[s.user_id] %}
    {% set isExcused = excused.has(s.user_id) %}
    {% include "app/points-grader/row.njk" %}
    {% endfor %}
  </tbody>
</table>
</div>
