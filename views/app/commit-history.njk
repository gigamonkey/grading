{% extends "app/layout.njk" %}
{% block title %}Commit History - Gradebook{% endblock %}
{% block content %}
<h1>Commit History</h1>
<form id="commit-history-form" hx-get="/commit-history" hx-target="#commit-history-results" hx-swap="innerHTML" hx-trigger="change, submit"
      onsubmit="event.preventDefault()" style="display: flex; gap: 1rem; align-items: center;">
  <label>Course
    <select name="course">
      <option value="">— pick a course —</option>
      {% for c in courses %}
      <option value="{{ c }}"{% if c == courseId %} selected{% endif %}>{{ c }}</option>
      {% endfor %}
    </select>
  </label>
  <label style="flex: 1">Path
    <input type="text" name="path" value="{{ repoPath }}" placeholder="e.g. csa/something or path/to/file.java" style="width: 100%">
  </label>
</form>
<div id="commit-history-results">
  {% include "app/commit-history/results.njk" %}
</div>
{% endblock %}
