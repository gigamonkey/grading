<td class="checklist-cell {{ value or 'empty' }}"
    hx-put="/checklist/{{ assignmentId }}/mark/{{ userId }}/{{ seq }}"
    hx-trigger="click"
    hx-target="this"
    hx-swap="outerHTML">{% if value == 'check' %}<i class="bi bi-check-lg"></i>{% elif value == 'x' %}<i class="bi bi-x-lg"></i>{% endif %}</td>
