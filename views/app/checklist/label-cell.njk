{% if editing %}
<th class="checklist-label editing">
  <input type="text" name="criteriaLabel" value="{{ criteriaLabel }}"
         hx-put="/checklist/{{ assignmentId }}/criteria/{{ seq }}/label"
         hx-trigger="change, keyup[key=='Enter']"
         hx-target="closest th"
         hx-swap="outerHTML"
         style="width:100%;margin:0"
         autofocus onfocus="this.select()"
         hx-on:keydown="if(event.key==='Escape'){event.preventDefault();htmx.ajax('GET','/checklist/{{ assignmentId }}/criteria/{{ seq }}/label',{target:this.closest('th'),swap:'outerHTML'})}">
</th>
{% else %}
<th class="checklist-label"
    hx-get="/checklist/{{ assignmentId }}/criteria/{{ seq }}/label/edit"
    hx-trigger="click"
    hx-target="this"
    hx-swap="outerHTML">
  {{ criteriaLabel }}
  <button class="checklist-delete-criterion"
          hx-delete="/checklist/{{ assignmentId }}/criteria/{{ seq }}"
          hx-target="#checklist-table"
          hx-swap="innerHTML"
          hx-trigger="click consume"
          hx-on:htmx:before-request="const th=this.closest('th');const idx=th.cellIndex;const table=th.closest('table');th.closest('tr').deleteCell(idx);table.querySelector('thead tr:nth-child(2)').deleteCell(idx-3);table.querySelectorAll('tbody tr').forEach(tr=>tr.deleteCell(idx))"><i class="bi bi-x"></i></button>
</th>
{% endif %}
