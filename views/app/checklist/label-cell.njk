{% if editing %}
<div class="checklist-label editing">
  <input type="text" name="criteriaLabel" value="{{ criteriaLabel }}"
         hx-put="/checklist/{{ assignmentId }}/criteria/{{ seq }}/label"
         hx-trigger="keyup[key=='Enter']"
         hx-target="closest .checklist-label"
         hx-swap="outerHTML"
         style="width:100%;margin:0"
         autofocus onfocus="this.select()"
         hx-on:keydown="if(event.key==='Escape'){event.preventDefault();this.dataset.cancelled='1';htmx.ajax('GET','/checklist/{{ assignmentId }}/criteria/{{ seq }}/label',{target:this.closest('.checklist-label'),swap:'outerHTML'})}"
         hx-on:blur="if(!this.dataset.cancelled){htmx.ajax('PUT','/checklist/{{ assignmentId }}/criteria/{{ seq }}/label',{target:this.closest('.checklist-label'),swap:'outerHTML',values:{criteriaLabel:this.value}})}">
</div>
{% else %}
<div class="checklist-label"
     hx-get="/checklist/{{ assignmentId }}/criteria/{{ seq }}/label/edit"
     hx-trigger="click"
     hx-target="this"
     hx-swap="outerHTML">
  {{ criteriaLabel }}
  <button class="checklist-delete-criterion"
          hx-delete="/checklist/{{ assignmentId }}/criteria/{{ seq }}"
          hx-target="#checklist-table"
          hx-swap="innerHTML"
          hx-trigger="click consume"
          hx-on:htmx:before-request="const th=this.closest('th');const idx=th.cellIndex;const table=th.closest('table');th.closest('tr').deleteCell(idx);table.querySelectorAll('tbody tr').forEach(tr=>tr.deleteCell(idx))"><i class="bi bi-x"></i></button>
</div>
{% endif %}
