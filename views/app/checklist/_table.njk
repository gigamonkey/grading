<div hx-vals='{"sort": "{{ sort }}", "dir": "{{ dir }}", "prevSort": "{{ prevSort if prevSort else '' }}", "prevDir": "{{ prevDir }}"}'>
<table class="checklist">
  <thead>
    <tr>
      {% set base = '/checklist/' + assignment.assignment_id %}
      {# When switching to a new column, current sort becomes the tiebreaker.
         When toggling direction on the active column, keep existing tiebreaker. #}
      {% macro sortLink(key, label, defaultSortDir) %}
        {% if sort == key %}
          {% set toggledDir = 'desc' if dir == 'asc' else 'asc' %}
          {% set href = base + '?sort=' + key + '&dir=' + toggledDir + ('&prevSort=' + prevSort + '&prevDir=' + prevDir if prevSort else '') %}
          <a href="{{ href }}" class="sort-active">{{ label }} <i class="bi {{ 'bi-arrow-up' if dir == 'asc' else 'bi-arrow-down' }}"></i></a>
        {% else %}
          {% set href = base + '?sort=' + key + '&dir=' + defaultSortDir + '&prevSort=' + sort + '&prevDir=' + dir %}
          <a href="{{ href }}">{{ label }}</a>
        {% endif %}
      {% endmacro %}
      <th>{{ sortLink('name', 'Name', 'asc') }} / {{ sortLink('github', 'Github', 'asc') }}</th>
      <th>{{ sortLink('score', 'Score', 'desc') }}</th>
      <th>{{ sortLink('points', 'Points', 'desc') }}</th>
      {% for c in criteria %}
        <th class="checklist-item">
          {% set assignmentId = assignment.assignment_id %}
          {% set seq = c.seq %}
          {% set criteriaLabel = c.label %}
          {% set editing = false %}
          {% include "app/checklist/label-cell.njk" %}
          {% set points = c.points %}
          {% set editing = false %}
          {% include "app/checklist/points-cell.njk" %}
        </th>
      {% endfor %}
      <th>
        <button hx-post="/checklist/{{ assignment.assignment_id }}/criteria"
                hx-vals='{"criteriaLabel": "-"}'
                hx-target="#checklist-table"
                hx-swap="innerHTML"><i class="bi bi-plus-lg"></i></button>
      </th>
  </thead>
  <tbody>
    {% for s in students %}
    {% set earned = studentPoints[s.user_id] %}
    {% set isExcused = excused.has(s.user_id) %}
    {% include "app/checklist/row.njk" %}
    {% endfor %}
  </tbody>
</table>
</div>
