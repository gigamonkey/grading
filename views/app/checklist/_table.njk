<table class="checklist">
  <thead>
    <tr>
      {% set base = '/checklist/' + assignment.assignment_id %}
      {# When switching to a new column, current sort becomes the tiebreaker.
         When toggling direction on the active column, keep existing tiebreaker. #}
      {% macro sortLink(key, label, defaultSortDir) %}
        {% if sort == key %}
          {% set toggledDir = 'desc' if dir == 'asc' else 'asc' %}
          {% set href = base + '?sort=' + key + '&dir=' + toggledDir + ('&prevSort=' + prevSort + '&prevDir=' + prevDir if prevSort else '') %}
          <a href="{{ href }}" class="sort-active">{{ label }} {{ '↑' if dir == 'asc' else '↓' }}</a>
        {% else %}
          {% set href = base + '?sort=' + key + '&dir=' + defaultSortDir + '&prevSort=' + sort + '&prevDir=' + dir %}
          <a href="{{ href }}">{{ label }}</a>
        {% endif %}
      {% endmacro %}
      <th rowspan="2">{{ sortLink('name', 'Name', 'asc') }} / {{ sortLink('github', 'Github', 'asc') }}</th>
      <th rowspan="2">{{ sortLink('score', 'Score', 'desc') }}</th>
      <th rowspan="2">{{ sortLink('points', 'Points', 'desc') }}</th>
      {% for c in criteria %}
        {% set assignmentId = assignment.assignment_id %}
        {% set seq = c.seq %}
        {% set criteriaLabel = c.label %}
        {% set editing = false %}
        {% include "app/checklist/label-cell.njk" %}
      {% endfor %}
      <th rowspan="2">
        <button hx-post="/checklist/{{ assignment.assignment_id }}/criteria"
                hx-vals='{"criteriaLabel": "-"}'
                hx-target="#checklist-table"
                hx-swap="innerHTML">+</button>
      </th>
    </tr>
    <tr>
      {% for c in criteria %}
        {% set assignmentId = assignment.assignment_id %}
        {% set seq = c.seq %}
        {% set points = c.points %}
        {% set editing = false %}
        {% include "app/checklist/points-cell.njk" %}
      {% endfor %}
    </tr>
  </thead>
  <tbody>
    {% for s in students %}
    {% set earned = studentPoints[s.user_id] %}
    <tr>
      <td>{{ s.sortable_name }} ({{ s.github }})</td>
      <td class="checklist-score"><span id="score-{{ s.user_id }}">{% if totalPoints %}{{ (earned / totalPoints * 100) | round }}%{% else %}-{% endif %}</span></td>
      <td class="checklist-score"><span id="points-{{ s.user_id }}">{{ earned }}/{{ totalPoints }}</span></td>
      {% for c in criteria %}
        {% set assignmentId = assignment.assignment_id %}
        {% set userId = s.user_id %}
        {% set seq = c.seq %}
        {% set value = markMap[s.user_id][c.seq] if markMap[s.user_id] else null %}
        {% include "app/checklist/cell.njk" %}
      {% endfor %}
      <td></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
