{% extends "app/layout.njk" %}
{% block title %}Grades to Update - Gradebook{% endblock %}
{% block content %}
<h1>Grades to Update</h1>
<select name="period"
  hx-get="/to-update"
  hx-trigger="change"
  hx-target="#to-update-tbody"
  hx-include="this">
  <option value="">All Periods</option>
  {% for p in periods %}
  <option value="{{ p }}" {% if p == period %}selected{% endif %}>Period {{ p }}</option>
  {% endfor %}
</select>
<table>
  <thead>
    <tr><th>Student</th><th>Period</th><th>IC Name</th><th>IC Points</th><th>DB Points</th></tr>
  </thead>
  <tbody id="to-update-tbody">
    {% include "app/to-update/tbody.njk" %}
  </tbody>
</table>
{% endblock %}
