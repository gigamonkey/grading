{% if isHtmx %}
<input type="hidden" id="hidden-sort" name="sort" form="commit-history-form" value="{{ sort or '' }}" hx-swap-oob="true">
<input type="hidden" id="hidden-dir" name="dir" form="commit-history-form" value="{{ dir or '' }}" hx-swap-oob="true">
<select id="student-select" name="user" form="commit-history-form" hx-swap-oob="true">
  <option value="">— pick a student —</option>
  <option value="all"{% if userParam == 'all' %} selected{% endif %}>All students</option>
  {% for s in courseStudents %}
  <option value="{{ s.user_id }}"{% if s.user_id == userId %} selected{% endif %}>{{ s.sortable_name }}</option>
  {% endfor %}
</select>
{% endif %}
{% if not courseId %}
<p>Pick a course to see commit history.</p>
{% elif not userParam %}
<p>Pick a student (or "All students") to see commit history.</p>
{% elif placeholderRows.length == 0 %}
<p>No students in this course.</p>
{% else %}
{% macro sortLink(key, label) %}{{ label }}<span class="sort-carets"
  ><a class="sort-up{% if sort == key and dir == 'desc' %} active{% endif %}"
      data-sort-key="{{ key }}" data-sort-dir="desc"
      href="#" onclick="event.preventDefault(); commitHistorySort(this);"
      ><i class="bi bi-caret-up-fill"></i></a
  ><a class="sort-down{% if sort == key and dir == 'asc' %} active{% endif %}"
      data-sort-key="{{ key }}" data-sort-dir="asc"
      href="#" onclick="event.preventDefault(); commitHistorySort(this);"
      ><i class="bi bi-caret-down-fill"></i></a
></span>{% endmacro %}
<div id="commit-history-spinner" style="margin: 0.5rem 0; color: #888;">
  Loading <span id="commit-history-pending-count">{{ placeholderRows.length }}</span> student{% if placeholderRows.length != 1 %}s{% endif %}…
</div>
<script id="school-days-data" type="application/json">{{ schoolDays | dump | safe }}</script>
<table class="data-table" id="commit-history-table"
       data-sort="{{ sort }}" data-dir="{{ dir }}"
       data-start-date="{{ startDate or '' }}" data-end-date="{{ endDate or '' }}">
  <thead>
    <tr>
      <th>{{ sortLink('name', 'Student') }}</th>
      <th>{{ sortLink('period', 'Period') }}</th>
      <th>{{ sortLink('github', 'GitHub') }}</th>
      <th>Commits <small id="commit-history-date-range" style="color:#888;font-weight:normal"></small></th>
      <th>{{ sortLink('days', 'Days') }}</th>
      <th>{{ sortLink('schoolPct', '% school days') }}</th>
      <th>{{ sortLink('rate', 'Commits/day') }}</th>
      <th>{{ sortLink('total', 'Total') }}</th>
    </tr>
  </thead>
  <tbody>
    {% for r in placeholderRows %}
    <tr data-pending="true"
        hx-get="/commit-history/row?course={{ courseId | urlencode }}&user={{ r.student.user_id | urlencode }}&path={{ repoPath | urlencode }}&startDate={{ startDate or '' }}&endDate={{ endDate or '' }}"
        hx-trigger="load" hx-swap="outerHTML">
      <td><a href="/students/{{ r.student.user_id }}">{{ r.student.sortable_name }}</a></td>
      <td>{{ r.student.period }}</td>
      <td>{% if r.student.github %}<a href="https://gigamonkeys.com/berkeley-high-cs/{{ r.student.github }}">{{ r.student.github }}</a>{% else %}&mdash;{% endif %}</td>
      <td colspan="5" style="color:#999">…</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
