{% if question %}
<div class="question-panel-content">
  <h2>Question {{ question.question_number + 1 }}
    <small>({{ question.kind }})</small>
    {% if totalStudents > 0 %}
    <span class="question-accuracy">{{ ((correctStudents / totalStudents) * 100) | round }}% ({{ correctStudents }} of {{ totalStudents }})</span>
    {% endif %}
  </h2>
  <pre class="question-text">{{ question.question }}</pre>

  {% if unscoredAnswers.length %}
  <div class="unscored-section">
    <h3>Unscored ({{ unscoredAnswers.length }} of {{ scoredAnswers.length + unscoredAnswers.length }})</h3>

    {% if question.kind in ['choices', 'ochoices', 'tf', 'yn'] %}
    <p class="scoring-hint">Click the correct answer:</p>
    {% for a in unscoredAnswers %}
    <form class="answer-row"
          hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/score-choice"
          hx-target="#question-panel" hx-swap="innerHTML">
      <input type="hidden" name="answer" value="{{ a.answer }}">
      <button type="submit" class="answer-button choice-button">
        {{ a.answer }}
        <span class="student-count">({{ a.student_count }})</span>
      </button>
    </form>
    {% endfor %}

    {% elif question.kind in ['mchoices', 'omchoices'] %}
    <p class="scoring-hint">Click to mark each answer correct or incorrect:</p>
    {% for a in unscoredAnswers %}
    <div class="answer-row mchoice-row">
      <span class="answer-text">{{ a.answer }}</span>
      <span class="student-count">({{ a.student_count }})</span>
      <form style="display: inline;"
            hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/toggle-mchoice"
            hx-target="#question-panel" hx-swap="innerHTML">
        <input type="hidden" name="answer" value="{{ a.answer }}">
        <input type="hidden" name="score" value="1">
        <button type="submit" class="answer-button mchoice-correct" title="Correct"><i class="bi bi-check-lg"></i></button>
      </form>
      <form style="display: inline;"
            hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/toggle-mchoice"
            hx-target="#question-panel" hx-swap="innerHTML">
        <input type="hidden" name="answer" value="{{ a.answer }}">
        <input type="hidden" name="score" value="-1">
        <button type="submit" class="answer-button mchoice-incorrect" title="Incorrect"><i class="bi bi-x-lg"></i></button>
      </form>
    </div>
    {% endfor %}

    {% elif question.kind == 'freeanswer' %}
    <p class="scoring-hint">Click check/x for 1/0, or a partial credit button:</p>
    {% for a in unscoredAnswers %}
    <div class="answer-row free-row">
      <span class="answer-text">{{ a.answer }}</span>
      <span class="student-count">({{ a.student_count }})</span>
      <form style="display: inline;"
            hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/score-free"
            hx-target="#question-panel" hx-swap="innerHTML">
        <input type="hidden" name="answer" value="{{ a.answer }}">
        <input type="hidden" name="score" value="1">
        <button type="submit" class="answer-button mchoice-correct" title="Score 1"><i class="bi bi-check-lg"></i></button>
      </form>
      <form style="display: inline;"
            hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/score-free"
            hx-target="#question-panel" hx-swap="innerHTML">
        <input type="hidden" name="answer" value="{{ a.answer }}">
        <input type="hidden" name="score" value="0">
        <button type="submit" class="answer-button mchoice-incorrect" title="Score 0"><i class="bi bi-x-lg"></i></button>
      </form>
      {% for v in [0.25, 0.5, 0.75] %}
      <form style="display: inline;"
            hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/score-free"
            hx-target="#question-panel" hx-swap="innerHTML">
        <input type="hidden" name="answer" value="{{ a.answer }}">
        <input type="hidden" name="score" value="{{ v }}">
        <button type="submit" class="answer-button partial-credit" title="Score {{ v }}">{{ v }}</button>
      </form>
      {% endfor %}
    </div>
    {% endfor %}

    {% else %}
    <p>Unknown question kind: {{ question.kind }}</p>
    {% endif %}
  </div>
  {% else %}
    {% if scoredAnswers.length %}
    <p class="info">All answers scored for this question.</p>
    {% else %}
    <p>No answers loaded for this question.</p>
    {% endif %}
  {% endif %}

  {% if scoredAnswers.length %}
  <div class="scored-section">
    <h3>Scored ({{ scoredAnswers.length }} of {{ scoredAnswers.length + unscoredAnswers.length }})</h3>
    {% for a in scoredAnswers %}
    <div class="scored-answer {% if a.score >= 1 %}correct{% elif a.score > 0 %}partial{% elif a.score < 0 %}incorrect{% else %}zero{% endif %}">
      <span class="answer-text">{{ a.answer }}</span>
      <span class="answer-score">{{ a.score }}</span>
      <form style="display: inline;"
            hx-post="/quiz-scoring/{{ assignmentId }}/question/{{ question.question_number }}/unscore"
            hx-target="#question-panel" hx-swap="innerHTML">
        <input type="hidden" name="answer" value="{{ a.answer }}">
        <button type="submit" class="rescore-button" title="Rescore"><i class="bi bi-pencil"></i></button>
      </form>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="question-panel-nav">
    {% if prevQuestion is not none %}
    <button hx-get="/quiz-scoring/{{ assignmentId }}/question/{{ prevQuestion }}"
            hx-target="#question-panel" hx-swap="innerHTML"><i class="bi bi-arrow-left"></i> Prev</button>
    {% endif %}
    {% if nextQuestion is not none %}
    <button hx-get="/quiz-scoring/{{ assignmentId }}/question/{{ nextQuestion }}"
            hx-target="#question-panel" hx-swap="innerHTML">Next <i class="bi bi-arrow-right"></i></button>
    {% endif %}
  </div>
</div>

<div id="question-nav" hx-swap-oob="innerHTML">
  {% include "app/quiz-scoring/question-nav.njk" %}
</div>
{% else %}
<p>No questions found for this assessment. Load questions via <code>markup-to-questions.py</code> first.</p>
{% endif %}
