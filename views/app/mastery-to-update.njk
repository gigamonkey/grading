{% extends "app/layout.njk" %}
{% block title %}Mastery Grades to Update - Gradebook{% endblock %}
{% block content %}
<h1>Mastery Grades to Update</h1>
<p>
  <button class="btn-subtle"
          hx-post="/assignments/reload-gradebook"
          hx-target="#gradebook-status"
          hx-swap="innerHTML">Reload Gradebook</button>
  <span id="gradebook-status"></span>
</p>
<table data-column-filters data-row-highlight>
  <thead>
    <tr><th data-column-filter="0">Period</th><th>Student</th><th data-column-filter="2">IC Name</th><th>IC Points</th><th>DB Points</th></tr>
  </thead>
  <tbody id="mastery-to-update-tbody"
         hx-get="/mastery-to-update/tbody"
         hx-trigger="gradebook-reloaded from:body"
         hx-swap="innerHTML">
    {% include "app/mastery-to-update/tbody.njk" %}
  </tbody>
</table>
<script src="/js/row-highlight.js"></script>
{% endblock %}
