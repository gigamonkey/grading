{% if mappings.length == 0 and standards.length == 0 %}
<p>No standards found for this course.</p>
{% else %}
<table>
  <thead>
    <tr><th>Standard</th><th>IC Name</th></tr>
  </thead>
  <tbody>
    {% for m in mappings %}
    <tr>
      <td>{{ m.standard }}</td>
      {% set courseId = course %}
      {% set standard = m.standard %}
      {% set icName = m.ic_name %}
      {% set editing = false %}
      {% include "app/mastery-ic-names/mapping-cell.njk" %}
    </tr>
    {% endfor %}
    {% for s in standards %}
    <tr>
      <td>{{ s }}</td>
      {% set courseId = course %}
      {% set standard = s %}
      {% set icName = null %}
      {% set editing = false %}
      {% include "app/mastery-ic-names/mapping-cell.njk" %}
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}
