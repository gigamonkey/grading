{% extends "app/layout.njk" %}
{% block title %}{{ assignment.title }} - Students{% endblock %}
{% block content %}
<h1>{{ assignment.title }} <small>{{ assignment.course_id }}</small>
  {% if hasJavaResults or hasJsResults %}
  <span style="font-size: 0.5em; opacity: 0.5;">
    <a href="#" title="Regrade all students" style="color: inherit;"
       hx-post="/assignments/{{ assignment.assignment_id }}/{% if hasJavaResults %}grade-java{% else %}grade-js{% endif %}"
       hx-target="#bulk-grade-status"
       hx-swap="innerHTML"
       onclick="event.preventDefault()">
      <i class="bi bi-arrow-clockwise"></i>
    </a>
    <span id="bulk-grade-status" style="font-size: 0.8em;"></span>
  </span>
  {% endif %}
</h1>
<p>
  {% if assignment.standard %}Standard: {{ assignment.standard }}{% endif %}
  {% if assignment.points %} &middot; {{ assignment.points }} points{% endif %}
  {% if hasScoring %} &middot; <a href="/quiz-scoring/{{ assignment.assignment_id }}">Scoring</a>{% endif %}
  {% if assignment.ic_name %} &middot; <a href="/ic-assignment/{{ assignment.ic_name }}">IC: {{ assignment.ic_name }}</a>{% endif %}
  {% set gradedViaUrls = {
    'rubric_scores': '/md-grader/' + assignment.assignment_id,
    'checklist_scores': '/checklist/' + assignment.assignment_id,
    'points_rubric_scores': '/points-grader/' + assignment.assignment_id,
    'form_assessment_scores': '/quiz-scoring/' + assignment.assignment_id
  } %}
  {% if provenance %}
    {% set label = provenance | replace("_scores", "") | replace("_", " ") %}
    &middot; Graded via:
    {% if gradedViaUrls[provenance] %}
      <a href="{{ gradedViaUrls[provenance] }}">{{ label }}</a>
    {% else %}
      {{ label }}
    {% endif %}
  {% endif %}
  {% if provenance == 'rubric_scores' %}
    <button hx-post="/md-grader/{{ assignment.assignment_id }}/fetch-submissions"
            hx-target="#fetch-result"
            hx-swap="innerHTML"
            class="btn-subtle"><i class="bi bi-cloud-download"></i> Fetch new</button>
    <span id="fetch-result"></span>
  {% endif %}
</p>
<input type="text" id="student-filter" placeholder="Filter students..." autofocus
       style="margin-bottom: 0.5em; padding: 0.25em 0.5em;">
<table class="data-table" data-column-filters>
  <thead>
    <tr>
      <th>Student</th>
      <th data-column-filter="1">Period</th>
      <th>Score</th>
      {% if assignment.points %}<th data-column-filter="3">Points</th>{% endif %}
      <th>SHA</th>
      <th>Submitted</th>
      <th></th>
    </tr>
  </thead>
  <tbody hx-get="/assignments/{{ assignment.assignment_id }}/students-tbody"
         hx-trigger="gradesUpdated from:body"
         hx-swap="innerHTML">
    {% include "app/assignments/students-tbody.njk" %}
  </tbody>
</table>
<style>
  .editable-score { cursor: pointer; text-decoration: underline dotted; }
  .editable-score input { width: 4em; font-size: inherit; padding: 0 0.2em; }
</style>
<script>
document.getElementById('student-filter').addEventListener('input', function () {
  const filter = this.value.toLowerCase();
  const rows = document.querySelectorAll('.data-table tbody tr');
  rows.forEach(row => {
    const name = row.cells[0].textContent.toLowerCase();
    row.style.display = name.includes(filter) ? '' : 'none';
  });
});

document.querySelector('.data-table').addEventListener('click', (e) => {
  const span = e.target.closest('.editable-score');
  if (!span || span.querySelector('input')) return;
  const current = span.dataset.score;
  const display = current !== '' ? (current * 100).toFixed(0) : '';
  const input = document.createElement('input');
  input.type = 'number';
  input.min = '0';
  input.max = '100';
  input.step = 'any';
  input.value = display;
  span.textContent = '';
  span.appendChild(input);
  input.focus();
  input.select();

  function submit() {
    const val = input.value.trim();
    if (val === '' || val === display) {
      span.textContent = current !== '' ? display + '%' : '\u2014';
      return;
    }
    const score = Number(val) / 100;
    if (isNaN(score) || score < 0 || score > 1) {
      span.textContent = current !== '' ? display + '%' : '\u2014';
      return;
    }
    const assignmentId = span.dataset.assignmentId;
    const userId = span.dataset.userId;
    htmx.ajax('POST', `/assignments/${assignmentId}/students/${userId}/direct-score`, {
      target: span,
      swap: 'innerHTML',
      values: { score },
    });
  }

  input.addEventListener('blur', submit);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); input.blur(); }
    if (e.key === 'Escape') { span.textContent = current !== '' ? display + '%' : '\u2014'; }
  });
});
</script>
{% endblock %}
