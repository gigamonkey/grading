{% extends "app/layout.njk" %}
{% block title %}{{ assignment.title }} - Students{% endblock %}
{% block content %}
<h1>{{ assignment.title }} <small>{{ assignment.course_id }}</small></h1>
<p>
  {% if assignment.standard %}Standard: {{ assignment.standard }}{% endif %}
  {% if assignment.points %} &middot; {{ assignment.points }} points{% endif %}
  {% if hasScoring %} &middot; <a href="/quiz-scoring/{{ assignment.assignment_id }}">Scoring</a>{% endif %}
  {% if assignment.ic_name %} &middot; <a href="/ic-assignment/{{ assignment.ic_name }}">IC: {{ assignment.ic_name }}</a>{% endif %}
</p>
<input type="text" id="student-filter" placeholder="Filter students..." autofocus
       style="margin-bottom: 0.5em; padding: 0.25em 0.5em;">
<table class="data-table" data-column-filters>
  <thead>
    <tr>
      <th>Student</th>
      <th data-column-filter="1">Period</th>
      <th>Score</th>
      {% if assignment.points %}<th data-column-filter="3">Points</th>{% endif %}
      <th>SHA</th>
      <th>Submitted</th>
      <th></th>
    </tr>
  </thead>
  <tbody hx-get="/assignments/{{ assignment.assignment_id }}/students-tbody"
         hx-trigger="gradesUpdated from:body"
         hx-swap="innerHTML">
    {% include "app/assignments/students-tbody.njk" %}
  </tbody>
</table>
<script>
document.getElementById('student-filter').addEventListener('input', function () {
  const filter = this.value.toLowerCase();
  const rows = document.querySelectorAll('.data-table tbody tr');
  rows.forEach(row => {
    const name = row.cells[0].textContent.toLowerCase();
    row.style.display = name.includes(filter) ? '' : 'none';
  });
});
</script>
{% endblock %}
