{% extends "app/layout.njk" %}
{% block title %}{{ assignment.title }} - Students{% endblock %}
{% block content %}
<h1>{{ assignment.title }} <small>{{ assignment.course_id }}</small></h1>
<p>
  {% if assignment.standard %}Standard: {{ assignment.standard }}{% endif %}
  {% if assignment.points %} &middot; {{ assignment.points }} points{% endif %}
  {% if hasScoring %} &middot; <a href="/quiz-scoring/{{ assignment.assignment_id }}">Scoring</a>{% endif %}
</p>

<input type="text" id="student-filter" placeholder="Filter students..." autofocus
       style="margin-bottom: 0.5em; padding: 0.25em 0.5em;">
<table class="data-table" data-column-filters>
  <thead>
    <tr>
      <th>Student</th>
      <th data-column-filter="1">Period</th>
      <th>Score</th>
      {% if assignment.points %}<th data-column-filter="3">Points</th>{% endif %}
      <th></th>
    </tr>
  </thead>
  <tbody>
    {% for s in students %}
    <tr{% if s.override %} class="override"{% endif %}>
      <td>
        {% if hasScoring %}
        <a href="/assignments/{{ assignment.assignment_id }}/students/{{ s.user_id }}/answers">{{ s.sortable_name }}</a>
        {% else %}
        <a href="/students/{{ s.user_id }}">{{ s.sortable_name }}</a>
        {% endif %}
        {% if hasScoring and s.github %}
        <span class="reload-status" style="display:inline-block; margin-left: 0.3em; opacity: 0.3;">
          <a href="#" title="Reload answers" style="color: inherit; font-size: 0.75em;"
             hx-post="/assignments/{{ assignment.assignment_id }}/students/{{ s.user_id }}/reload-answers"
             hx-target="closest .reload-status"
             hx-swap="innerHTML"
             hx-indicator="closest .reload-status"
             onclick="event.preventDefault()">
            <i class="bi bi-arrow-clockwise"></i>
          </a>
        </span>
        {% endif %}
      </td>
      <td>{{ s.period }}</td>
      <td>{% if s.score != null %}{{ (s.score * 100) | round }}%{% else %}&mdash;{% endif %}</td>
      {% if assignment.points %}<td>{% if s.points != null %}{{ s.points }} / {{ s.max_points }}{% else %}&mdash;{% endif %}</td>{% endif %}
      <td>{% if s.override %}override{% endif %}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
<script>
document.getElementById('student-filter').addEventListener('input', function () {
  const filter = this.value.toLowerCase();
  const rows = document.querySelectorAll('.data-table tbody tr');
  rows.forEach(row => {
    const name = row.cells[0].textContent.toLowerCase();
    row.style.display = name.includes(filter) ? '' : 'none';
  });
});
</script>
{% endblock %}
