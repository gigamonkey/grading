{% if error %}
<p class="error">{{ error }}</p>
{% elif assignment %}
<p class="info">{{ assignment.title }} ({{ assignment.course_id }})</p>
<div id="standard-field" hx-swap-oob="true">
  <label>Standard
    <input type="text" name="standard" required list="standards-list">
    <datalist id="standards-list">
      {% for s in standards %}
      <option value="{{ s }}">
      {% endfor %}
    </datalist>
  </label>
</div>
{% endif %}
