<tr id="apv-row-{{ a.assignment_id }}">
  <td><a href="#" hx-get="/assignments/{{ a.assignment_id }}/api-json"
                  hx-target="body" hx-swap="beforeend"
                  onclick="document.getElementById('api-json-dialog')?.remove()">{{ a.assignment_id }}</a></td>
  <td><a href="/assignments/{{ a.assignment_id }}/students">{{ a.title }}</a></td>
  <td>{{ a.course_id }}</td>
  <td>{% if a.kind %}{{ a.kind }}{% else %}<i class="bi bi-arrow-clockwise"
     style="cursor:pointer"
     title="Fetch assignment kind from server"
     hx-post="/assignments/{{ a.assignment_id }}/refresh-kind"
     hx-target="#apv-row-{{ a.assignment_id }}"
     hx-swap="outerHTML"></i>{% endif %}</td>
  <td>{{ a.date }}</td>
  {% include "app/assignments/type-cell.njk" %}
  {% include "app/assignments/standard-cell.njk" %}
  {% include "app/assignments/ic-name-cell.njk" %}
  {% include "app/assignments/points-cell.njk" %}
  <td>
    {% if not a.has_scores %}
      {% if a.kind == 'coding' %}
        <button hx-post="/assignments/{{ a.assignment_id }}/grade-js"
                hx-target="#grade-status-{{ a.assignment_id }}"
                hx-swap="innerHTML">Grade JS</button>
        <span id="grade-status-{{ a.assignment_id }}"></span>
      {% elif a.kind == 'questions' %}
        <a href="/quiz-scoring/{{ a.assignment_id }}"><button type="button">Grade Quiz</button></a>
      {% endif %}
    {% endif %}
  </td>
</tr>
