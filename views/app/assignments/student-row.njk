<tr id="student-row-{{ s.user_id }}"{% if s.override %} class="override"{% endif %}
    hx-get="/assignments/{{ assignment.assignment_id }}/students/{{ s.user_id }}/row"
    hx-trigger="answers-reloaded[event.detail.value=='{{ s.user_id }}'] from:body, js-reloaded[event.detail.value=='{{ s.user_id }}'] from:body, java-reloaded[event.detail.value=='{{ s.user_id }}'] from:body, score-updated[event.detail.value=='{{ s.user_id }}'] from:body"
    hx-swap="outerHTML">
  <td>
    <a href="/students/{{ s.user_id }}">{{ s.sortable_name }}</a>
    {% if (hasScoring or hasJsResults or hasJavaResults) and s.github %}
    <span class="reload-status" style="display:inline-block; margin-left: 0.3em; opacity: 0.3;">
      <a href="#" title="Reload and grade" style="color: inherit; font-size: 0.75em;"
         hx-post="/assignments/{{ assignment.assignment_id }}/students/{{ s.user_id }}/{% if hasScoring %}reload-answers{% elif hasJavaResults %}reload-java{% else %}reload-js{% endif %}"
         hx-target="closest .reload-status"
         hx-swap="innerHTML"
         hx-indicator="closest .reload-status"
         onclick="event.preventDefault()">
        <i class="bi bi-arrow-clockwise"></i>
      </a>
    </span>
    {% endif %}
  </td>
  <td>{{ s.period }}</td>
  <td>{% if provenance == 'direct_scores' %}
    <span class="editable-score" data-user-id="{{ s.user_id }}" data-assignment-id="{{ assignment.assignment_id }}" data-score="{{ s.score if s.score != null else '' }}">{% if s.score != null %}{{ (s.score * 100) | round }}%{% else %}&mdash;{% endif %}</span>
  {% elif s.score != null %}<a href="/assignments/{{ assignment.assignment_id }}/students/{{ s.user_id }}/answers">{{ (s.score * 100) | round }}%</a>{% else %}&mdash;{% endif %}</td>
  {% if assignment.points %}<td>{% if s.points != null %}<a href="/assignments/{{ assignment.assignment_id }}/students/{{ s.user_id }}/answers">{{ s.points }} / {{ s.max_points }}</a>{% else %}&mdash;{% endif %}</td>{% endif %}
  <td>{% if s.sha %}<code title="{{ s.sha }}">{{ s.sha | truncate(7, true, '') }}</code>{% else %}&mdash;{% endif %}</td>
  <td>{% if s.graded_at %}{{ s.graded_at | epochDate }}{% else %}&mdash;{% endif %}</td>
  <td>{% if s.override %}override{% endif %}</td>
</tr>
