{% extends "app/layout.njk" %}
{% block title %}Students - Gradebook{% endblock %}
{% block content %}
<h1>Students</h1>
<input type="search" placeholder="Search students..."
  value="{{ search or '' }}"
  hx-get="/students"
  hx-trigger="input delay:300ms"
  hx-target="#students-tbody"
  hx-include="this"
  name="search">
<table class="fit" data-column-filters>
  <thead>
    <tr><th>Student #</th><th data-column-filter="1">Course</th><th data-column-filter="2">Period</th><th>Name</th><th>Sortable Name</th><th>Email</th><th>GitHub</th><th></th></tr>
  </thead>
  <tbody id="students-tbody">
    {% include "app/students/tbody.njk" %}
  </tbody>
</table>
{% endblock %}
