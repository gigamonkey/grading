{% extends "app/layout.njk" %}
{% block title %}Score Overrides - Gradebook{% endblock %}
{% block content %}
<h1>Score Overrides</h1>
<p><a href="/overrides/new">+ New Override</a></p>
<table data-column-filters>
  <thead>
    <tr><th>Student</th><th data-column-filter="1">Period</th><th data-column-filter="2">Course</th><th>Assignment</th><th>Score</th><th>Reason</th></tr>
  </thead>
  <tbody id="overrides-tbody">
    {% include "app/overrides/tbody.njk" %}
  </tbody>
</table>
{% endblock %}
