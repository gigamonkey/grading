<div class="md-grader-sidebar" id="md-grader-sidebar">
  <h3>Rubric</h3>
  <div class="md-grader-score" id="md-grader-score">
    {% include "app/md-grader/score.njk" %}
  </div>
  <div class="md-grader-criteria" id="md-grader-criteria">
    {% for item in items %}
      {% set seq = item.seq %}
      {% set fraction = markMap[student.user_id][item.seq] if markMap[student.user_id] else undefined %}
      {% set c = item %}
      {% if item.kind == 'word_count' %}
        <div class="md-grader-criterion">
          <div class="md-grader-criterion-header">
            {% set editing = (editingLabelSeq == item.seq) %}
            {% include "app/md-grader/label.njk" %}
            {% set editing = (editingPointsSeq == item.seq) %}
            {% include "app/md-grader/points.njk" %}
          </div>
          {% include "app/md-grader/word-count-mark.njk" %}
        </div>
      {% else %}
        <div class="md-grader-criterion md-grader-criterion-row">
          {% include "app/md-grader/rubric-mark.njk" %}
          {% set editing = (editingLabelSeq == item.seq) %}
          {% include "app/md-grader/label.njk" %}
          {% set editing = (editingPointsSeq == item.seq) %}
          {% include "app/md-grader/points.njk" %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="md-grader-add-buttons">
    <button hx-post="/md-grader/{{ assignmentId }}/rubric"
            hx-vals='{"label": "-", "points": "1", "userId": "{{ student.user_id }}", "branch": "{{ branch }}", "filePath": "{{ filePath }}"}'
            hx-target="#md-grader-sidebar"
            hx-swap="outerHTML"><i class="bi bi-plus-lg"></i> Add item</button>
    <button onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'':'none'"><i class="bi bi-body-text"></i> Word count</button>
    <form class="md-grader-wc-form" style="display:none"
          hx-post="/md-grader/{{ assignmentId }}/word-count-item"
          hx-target="#md-grader-sidebar"
          hx-swap="outerHTML">
      <input type="hidden" name="userId" value="{{ student.user_id }}">
      <input type="hidden" name="branch" value="{{ branch }}">
      <input type="hidden" name="filePath" value="{{ filePath }}">
      <label>Min words <input type="number" name="minWords" value="200" min="1" style="width:5rem"></label>
      <label>Points <input type="number" name="points" value="10" min="0" step="1" style="width:4rem"></label>
      <button type="submit">Add</button>
    </form>
  </div>
</div>
