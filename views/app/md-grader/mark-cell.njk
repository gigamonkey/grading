<div class="md-grader-mark {{ value or 'empty' }}"
     hx-put="/md-grader/{{ assignmentId }}/mark/{{ student.user_id }}/{{ seq }}?branch={{ branch | urlencode }}&filePath={{ filePath | urlencode }}"
     hx-trigger="click"
     hx-target="this"
     hx-swap="outerHTML">{% if value == 'check' %}<i class="bi bi-check-lg"></i>{% elif value == 'x' %}<i class="bi bi-x-lg"></i>{% else %}<i class="bi bi-dash"></i>{% endif %}</div>
