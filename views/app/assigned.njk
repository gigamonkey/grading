{% extends "app/layout.njk" %}
{% block title %}Assigned - Gradebook{% endblock %}
{% block content %}
<h1>Assigned</h1>
<p>
  <a href="/assignments">&larr; Back to Assignments</a>
</p>
<div class="server-assignments-controls">
  <input type="search" placeholder="Search assignments..."
    value="{{ search or '' }}"
    hx-get="/assigned"
    hx-trigger="input delay:300ms"
    hx-target="#server-assignments-tbody"
    hx-include=".server-assignments-controls"
    name="search">
  <label>
    <input type="checkbox" name="showNotForGrade" value="1"
      {% if showNotForGrade %}checked{% endif %}
      hx-get="/assigned"
      hx-trigger="change"
      hx-target="#server-assignments-tbody"
      hx-include=".server-assignments-controls">
    Show not-for-grade
  </label>
</div>
<table data-column-filters>
  <thead>
    <tr>
      <th>ID</th><th>Title</th><th data-column-filter="2">Course</th><th data-column-filter="3">Kind</th><th>Date</th><th></th>
    </tr>
  </thead>
  <tbody id="server-assignments-tbody">
    {% include "app/assigned-tbody.njk" %}
  </tbody>
</table>
{% endblock %}
