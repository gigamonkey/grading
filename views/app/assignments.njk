{% extends "app/layout.njk" %}
{% block title %}Assignments - Gradebook{% endblock %}
{% block content %}
<h1>Assignments</h1>
<p>
  <a href="/assignments/new">+ New Assignment</a>
  &middot;
  <button class="btn-subtle"
          hx-post="/assignments/reload-gradebook"
          hx-target="#gradebook-status"
          hx-swap="innerHTML">Reload Gradebook</button>
  <span id="gradebook-status"></span>
</p>
<input type="search" placeholder="Search assignments..."
  value="{{ search or '' }}"
  hx-get="/assignments"
  hx-trigger="input delay:300ms"
  hx-target="#assignments-tbody"
  hx-include="this"
  name="search">
<table data-column-filters>
  <thead>
    <tr>
      <th>ID</th><th>Title</th><th data-column-filter="2">Course</th><th data-column-filter="3">Kind</th><th>Date</th><th data-column-filter="5">Type</th><th data-column-filter="6">Standard</th><th>IC Name</th><th class="text-center">Points</th><th class="text-center">Grading</th>
    </tr>
  </thead>
  <tbody id="assignments-tbody">
    {% include "app/assignments/tbody.njk" %}
  </tbody>
</table>
{% endblock %}
