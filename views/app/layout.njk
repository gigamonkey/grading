<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Gradebook{% endblock %}</title>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/app.css">
  <link rel="icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <script src="/js/column-filter.js" defer></script>
  <script defer>
    document.addEventListener('click', (e) => {
      const copyable = e.target.closest('.copyable');
      if (!copyable) return;
      const icon = copyable.querySelector('.copy-icon');
      if (!icon) return;
      icon.classList.remove('bi-clipboard');
      icon.classList.add('bi-clipboard-check', 'copied');
      setTimeout(() => {
        icon.classList.remove('bi-clipboard-check', 'copied');
        icon.classList.add('bi-clipboard');
      }, 1000);
    });
  </script>
</head>
<body>
  <nav>
    <a href="/">Dashboard</a>
    <a href="/assignments">Assignments</a>
    <a href="/students">Students</a>
    <a href="/overrides">Overrides</a>
    <a href="/ad-hoc-mastery">Ad Hoc Mastery</a>
    <a href="/to-update">To Update</a>
    <a href="/mastery-to-update">Mastery To Update</a>
    <a href="/standards">Standards</a>
    <a href="/zeros">Zeros</a>
    <a href="/speedruns">Speedruns</a>
    <a href="/checklist">Checklist</a>
    <a href="/quiz-scoring">Quiz Scoring</a>
  </nav>
  <main>
    {% block content %}{% endblock %}
  </main>
</body>
</html>
